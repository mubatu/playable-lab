{
  "id": "blast",
  "name": "Blast",
  "description": "Tap matching objects in a configurable grid before time runs out.",
  "entry": "src/index.html",
  "assets": [
    {
      "id": "background",
      "label": "Background",
      "accept": "image/png",
      "required": true,
      "multiple": false,
      "path": "src/assets/background.png"
    },
    {
      "id": "endBackground",
      "label": "End Background",
      "accept": "image/png",
      "required": true,
      "multiple": false,
      "path": "src/assets/end-background.png"
    },
    {
      "id": "objects",
      "label": "Objects",
      "accept": "image/png",
      "required": true,
      "multiple": true,
      "min": 1,
      "directory": "src/assets",
      "filePattern": "object-{index}.png"
    },
    {
      "id": "soundtrack",
      "label": "Soundtrack",
      "accept": "audio/mpeg,.mp3",
      "required": false,
      "multiple": false,
      "path": "src/assets/soundtrack.mp3"
    },
    {
      "id": "blast",
      "label": "Blast Sound",
      "accept": "audio/mpeg,.mp3",
      "required": false,
      "multiple": false,
      "path": "src/assets/blast.mp3"
    }
  ],
  "config": [
    {
      "path": "gameplay.durationSeconds",
      "label": "Duration",
      "type": "number",
      "default": 120,
      "min": 5,
      "max": 200,
      "step": 1
    },
    {
      "path": "gameplay.targetObjectIndex",
      "label": "Target Object Index",
      "type": "number",
      "default": 0,
      "min": 0,
      "max": 4,
      "step": 1
    },
    {
      "path": "gameplay.targetCount",
      "label": "Target Count",
      "type": "number",
      "default": 20,
      "min": 1,
      "max": 99,
      "step": 1
    },
    {
      "path": "gameplay.minBlastGroupSize",
      "label": "Minimum Blast Group Size",
      "type": "number",
      "default": 2,
      "min": 2,
      "max": 8,
      "step": 1
    },
    {
      "path": "ui.instructionText",
      "label": "Instruction Text",
      "type": "string",
      "default": "BLAST THE GERMS!"
    },
    {
      "path": "grid.rows",
      "label": "Grid Rows",
      "type": "number",
      "default": 5,
      "min": 2,
      "max": 10,
      "step": 1
    },
    {
      "path": "grid.columns",
      "label": "Grid Columns",
      "type": "number",
      "default": 5,
      "min": 2,
      "max": 8,
      "step": 1
    },
    {
      "path": "grid.top",
      "label": "Grid Top Offset",
      "type": "number",
      "default": 600,
      "min": 0,
      "max": 1920,
      "step": 1,
      "advanced": true
    },
    {
      "path": "grid.gapX",
      "label": "Grid Horizontal Gap",
      "type": "number",
      "default": 18,
      "min": 0,
      "max": 80,
      "step": 1,
      "advanced": true
    },
    {
      "path": "grid.gapY",
      "label": "Grid Vertical Gap",
      "type": "number",
      "default": 18,
      "min": 0,
      "max": 80,
      "step": 1,
      "advanced": true
    },
    {
      "path": "grid.objectSize",
      "label": "Object Size",
      "type": "number",
      "default": 150,
      "min": 48,
      "max": 240,
      "step": 1
    },
    {
      "path": "grid.fallSpeed",
      "label": "Object Fall Speed",
      "type": "number",
      "default": 1500,
      "min": 500,
      "max": 8000,
      "step": 100,
      "advanced": true
    },
    {
      "path": "grid.targetSpawnChance",
      "label": "Target Spawn Chance",
      "type": "number",
      "default": 0.2,
      "min": 0,
      "max": 1,
      "step": 0.01,
      "advanced": true
    },
    {
      "path": "ui.endButton.text",
      "label": "End Button Text",
      "type": "string",
      "default": "PLAY NOW!"
    },
    {
      "path": "ui.endButton.backgroundColor",
      "label": "End Button Color",
      "type": "color",
      "default": "#003678"
    }
  ]
}
